---
import '../styles/experience-item.css';
interface Props {
  title: string;
  dates: string;
  description?: string;
  bullets?: string[];
}

const { title, dates, description, bullets } = Astro.props;
---

<div class="exp-item">
  <div class="exp-item__dot"></div>
  <div class="exp-item__content">
    <h4 class="exp-item__title">{title}</h4>
    <span class="text-meta exp-item__dates">{dates}</span>
    {description && <p class="exp-item__desc">{description}</p>}
    {bullets && bullets.length > 0 && (
      <ul class="exp-item__bullets">
        {bullets.map((b) => <li>{b}</li>)}
      </ul>
    )}
  </div>
</div>
